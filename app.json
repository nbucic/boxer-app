{
  "expo": {
    "name": "Boxer app",
    "slug": "boxer-app",
    "scheme": "boxer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/box-64.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/box-64.png",
        "backgroundColor": "#000000"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "app.boxer.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.nbucic.boxerapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/box-64.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "sitemap": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/box-64.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "inset-swipe"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "visibility": "hidden",
        "behavior": "inset-swipe"
      },
      "eas": {
        "projectId": "6d2d4084-28e2-44c2-8ce9-fd45a1a2ac05"
      }
    }
  }
}
